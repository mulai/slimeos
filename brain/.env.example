# Slime OS Brain — Environment Variables
# Copy to .env and fill in all values before running docker compose up.
# NEVER commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=slimeos.com
AUTH_DOMAIN=auth.slimeos.com

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Authelia secrets (generate with: openssl rand -hex 64) ───────────────────
AUTHELIA_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
AUTHELIA_SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password

# ── SMTP (for Authelia MFA emails — using Lark Suite) ────────────────────────
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_USER=noreply@slimeos.com
SMTP_PASSWORD=CHANGE_ME_lark_app_password

# ── WireGuard ─────────────────────────────────────────────────────────────────
WG_SERVER_URL=vpn.slimeos.com
WG_PORT=51820
WG_PEERS=10      # number of client configs to pre-generate

# ── Desktop VM ───────────────────────────────────────────────────────────────
SLIME_DESKTOP_USER=slimeuser
SLIME_DESKTOP_PASS=CHANGE_ME_strong_password
