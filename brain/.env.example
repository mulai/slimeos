# Slime OS Brain — Environment Variables
# Copy to .env and fill in all values before running docker compose up.
# NEVER commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=slimeos.com
AUTH_DOMAIN=auth.slimeos.com

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── Authelia secrets (generate with: openssl rand -hex 64) ───────────────────
AUTHELIA_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
AUTHELIA_SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_password

# ── SMTP (for Authelia MFA emails — using Lark Suite) ────────────────────────
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_USER=noreply@slimeos.com
SMTP_PASSWORD=CHANGE_ME_lark_app_password

# ── WireGuard ─────────────────────────────────────────────────────────────────
WG_SERVER_URL=vpn.slimeos.com
WG_PORT=51820
WG_PEERS=10      # number of client configs to pre-generate

# ── Desktop VM ───────────────────────────────────────────────────────────────
SLIME_DESKTOP_USER=slimeuser
SLIME_DESKTOP_PASS=CHANGE_ME_strong_password

# ── Power management (cloud Brain auto-deallocate / wake-on-connect) ─────────
# Optional — leave POWER_VMS empty and the power service runs but manages
# nothing. Create the Azure service principal once, scoped to just the VM:
#
#   az ad sp create-for-rbac --name slimeos-power \
#     --role "Virtual Machine Contributor" \
#     --scopes /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Compute/virtualMachines/<vm>
#
# ⚠ Record the client secret's expiry date (default 1 year). When it
# expires, wakes fail and auto-deallocation stops — fails safe, but the VM
# then bills 24/7 again until the secret is rotated here.
AZURE_TENANT_ID=CHANGE_ME_tenant_guid
AZURE_CLIENT_ID=CHANGE_ME_appId_guid
AZURE_CLIENT_SECRET=CHANGE_ME_sp_password
# <wireguard-peer-ip>=<subscriptionId>/<resourceGroup>/<vmName>, comma-separated
POWER_VMS=10.10.0.3=00000000-0000-0000-0000-000000000000/SLIMEOS-WINDOWS/slimeos-windows
# Minutes with zero RDP flows AND near-zero tunnel traffic before the VM
# is deallocated (both signals must agree — see brain/power/main.go)
POWER_IDLE_MINUTES=20
# Per-minute WireGuard transfer (bytes) below which the VM peer counts as
# idle. Floor is WG keepalives ~700 B/min; an idle-but-connected RDP
# session measures ~15 KB/min. Default 4096 sits between them.
#POWER_IDLE_XFER_BYTES=4096
