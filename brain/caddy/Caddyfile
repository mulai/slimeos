# ── Authelia SSO portal ────────────────────────────────────────────────────────
auth.slimeos.com {
    reverse_proxy authelia:9091
}

# ── Slime account dashboard (placeholder — Phase 2) ──────────────────────────
dashboard.slimeos.com {
    forward_auth authelia:9091 {
        uri /api/verify?rd=https://auth.slimeos.com
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
    # Placeholder: serve a static page until the dashboard is built
    respond "Slime OS Dashboard — Coming Soon" 200
}

